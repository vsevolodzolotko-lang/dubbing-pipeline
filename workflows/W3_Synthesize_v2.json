    {
      "parameters": {
        "jsCode": "const checkItem = $('Check Timing + Pad').item.json;\nconst job = $('Expand TTS Jobs').item.json;\nconst driveResp = $input.first().json;\n\nreturn [{\n  json: {\n    row_key:            `${checkItem.segment_id}_${checkItem.lang}`,\n    segment_id:         checkItem.segment_id,\n    lang:               checkItem.lang,\n    text_translated:    job.text,\n    en_start_sec:       job.en_start_sec,\n    en_duration_sec:    checkItem.en_duration_sec,\n    real_duration_sec:  checkItem.real_duration_sec,\n    final_speed:        checkItem.final_speed,\n    needs_attention:    checkItem.needs_attention ? 'TRUE' : 'FALSE',\n    audio_drive_file_id: driveResp.id || '',\n  }\n}];"
      },
