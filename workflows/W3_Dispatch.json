      "parameters": {
        "jsCode": "// Continuation-chain kickoff/step. lesson_id from parent (W_Master/manual). lang_index =\n// which language to process this hop (default 0 = start of chain). The chain advances by\n// W3 calling this dispatcher back with the next index when a language finishes.\nconst incoming = $input.first()?.json || {};\nconst lesson_id = incoming.lesson_id || null;\nconst lang_index = Number(incoming.lang_index) || 0;\nreturn [{ json: { lesson_id, lang_index } }];\n"
      },
