    {
      "parameters": {
        "jsCode": "// Resolve langs[lang_index] from config active_langs and hand W3 an explicit single lang +\n// the flags it needs to (a) gate Slack to the final language and (b) chain to the next one.\nconst cfg = {};\n$('Read Config').all().forEach(i => { if (i.json && i.json.key) cfg[i.json.key] = i.json.value; });\nconst langs = (cfg.active_langs || 'de,es,fr,it,pl,pt,tr').split(',').map(s => s.trim()).filter(Boolean);\nif (!langs.length) throw new Error('active_langs produced empty list — check config');\nconst { lesson_id, lang_index } = $('Get Params').first().json;\nconst idx = Math.min(Math.max(lang_index, 0), langs.length - 1);\nreturn [{ json: {\n  lesson_id,\n  lang: langs[idx],\n  is_last_lang: idx === langs.length - 1,\n  next_index: idx + 1,\n} }];\n"
      },
