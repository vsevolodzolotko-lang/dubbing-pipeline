    {
      "parameters": {
        "jsCode": "// Accept params from either Execute Workflow Trigger (parent passes {file_id, lesson_id})\n// or Manual Trigger (fall back to hardcoded test defaults).\nconst incoming = $input.first()?.json || {};\nconst file_id = incoming.file_id || '1gDRuwWEtfeHcQwEjEMbg4cQOHZQC_nYR';\nconst lesson_id = incoming.lesson_id || 'sleep_001';\nif (!file_id) throw new Error('Missing file_id');\nif (!lesson_id) throw new Error('Missing lesson_id');\nreturn [{ json: { file_id, lesson_id } }];"
      },
      "id": "6f6bbf51-b7cf-4bdc-b47e-7393d646dd9a",
      "name": "Get Params",
