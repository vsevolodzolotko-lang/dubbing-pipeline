    {
      "parameters": {
        "method": "POST",
        "url": "https://api.deepgram.com/v1/listen?model=nova-3&punctuate=true&smart_format=true&utterances=true&utt_split=1.5&language=en",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "binaryData",
        "inputDataFieldName": "data",
        "options": {}
      },
      "id": "139ecde9-c26e-491c-acf7-dcd913078947",
      "name": "Deepgram STT",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        608,
        80
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "pkPNMab5kHBstRKT",
          "name": "Deepgram account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst lesson_id = $('Get Params').first().json.lesson_id;\nconst MAX_CHARS            = 150;\nconst MAX_GAP_FOR_GROUPING = 1.0;\n\nconst alt           = data.results?.channels?.[0]?.alternatives?.[0];\nconst paragraphs    = alt?.paragraphs?.paragraphs || [];\nconst audioDuration = parseFloat(data.metadata?.duration) || null;\nconst segments      = [];\nlet current         = null;\n\nfunction flush() { if (current) { segments.push(current); current = null; } }\n\nfor (const para of paragraphs) {\n  flush();\n  for (const s of (para.sentences || [])) {\n    if (current === null) {\n      current = { text: s.text, start: s.start, end: s.end };\n      continue;\n    }\n    const combined = current.text + ' ' + s.text;\n    const gap      = s.start - current.end;\n    if (combined.length <= MAX_CHARS && gap <= MAX_GAP_FOR_GROUPING) {\n      current.text = combined;\n      current.end  = s.end;\n    } else {\n      flush();\n      current = { text: s.text, start: s.start, end: s.end };\n    }\n  }\n}\nflush();\n\n// Fallback if paragraphs missing\nif (!segments.length) {\n  const utts = data.results?.utterances || [];\n  if (!utts.length) throw new Error('No sentences/utterances returned from Deepgram');\n  for (const u of utts) segments.push({ text: u.transcript, start: u.start, end: u.end });\n}\n\n// Extend last segment to full audio duration so concatenated slot sum = EN total.\n// Deepgram's last word.end stops at the last spoken word; audio may have trailing silence.\nif (audioDuration && segments.length > 0) {\n  const last = segments[segments.length - 1];\n  if (audioDuration > last.end) {\n    last.end = audioDuration;\n  }\n}\n\nreturn segments.map((seg, i) => ({\n  json: {\n    segment_id: lesson_id + '_seg_' + String(i + 1).padStart(3, '0'),\n    lesson_id,\n    en_text: seg.text,\n    en_start_sec: parseFloat(seg.start.toFixed(3)),\n    en_end_sec: parseFloat(seg.end.toFixed(3)),\n    en_duration_sec: parseFloat((seg.end - seg.start).toFixed(3)),\n    de_text: '',\n    es_text: '',\n    fr_text: '',\n    pl_text: '',\n    pt_text: '',\n    it_text: '',\n    tr_text: '',\n    status: 'pending',\n    notes: '',\n  }\n}));"
      },
