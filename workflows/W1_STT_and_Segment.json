    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst utterances = data.results?.utterances || [];\nconst lesson_id = 'sleep_001';\n\nif (!utterances.length) throw new Error('No utterances returned from Deepgram');\n\n// Each Deepgram utterance is a natural sentence-level segment, split by silence + punctuation.\n// We use them directly — no own sentence-detection or merge logic needed (Scribe-legacy quirk).\n\nreturn utterances.map((u, i) => ({\n  json: {\n    segment_id: lesson_id + '_seg_' + String(i + 1).padStart(3, '0'),\n    lesson_id,\n    en_text: u.transcript,\n    en_start_sec: parseFloat(u.start.toFixed(3)),\n    en_end_sec: parseFloat(u.end.toFixed(3)),\n    en_duration_sec: parseFloat((u.end - u.start).toFixed(3)),\n    de_text: '',\n    es_text: '',\n    fr_text: '',\n    pl_text: '',\n    pt_text: '',\n    it_text: '',\n    tr_text: '',\n    status: 'pending',\n    notes: '',\n  }\n}));"
      },
      "id": "6b5c97ce-a22f-4319-8039-863b8146373b",
