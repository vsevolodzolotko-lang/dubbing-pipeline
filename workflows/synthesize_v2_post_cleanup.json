    {
      "parameters": {
        "jsCode": "// Estimate mp3 duration from binary size\n// Works for CBR mp3 (ElevenLabs output_format=mp3_44100_192 = 192 kbps)\n\nconst inputItem = $input.first();\nconst binary = inputItem.binary?.data;\n\nif (!binary) {\n  throw new Error('No binary from TTS. Check Response Format = File in HTTP Request');\n}\n\nlet fileSizeBytes;\n\nif (typeof binary === 'string') {\n  fileSizeBytes = Buffer.from(binary, 'base64').length;\n} else if (binary.data) {\n  fileSizeBytes = Buffer.from(binary.data, 'base64').length;\n} else {\n  fileSizeBytes = Buffer.byteLength(binary);\n}\n\nconst BITRATE_BYTES_PER_SEC = 24000;\nconst durationSec = fileSizeBytes / BITRATE_BYTES_PER_SEC;\nconst realDuration = parseFloat(durationSec.toFixed(3));\n\nconsole.log(`${inputItem.json.segment_id}_${inputItem.json.lang}: ${realDuration}s (${(fileSizeBytes/1024).toFixed(1)} KB)`);\n\nreturn [{\n  json: {\n    ...inputItem.json,\n    real_duration_sec: realDuration,\n    file_size_bytes: fileSizeBytes\n  },\n  binary: inputItem.binary\n}];"
      },
