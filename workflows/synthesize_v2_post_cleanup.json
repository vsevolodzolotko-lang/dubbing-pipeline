    {
      "parameters": {
        "jsCode": "const voices = $('Get Voices').all().map(item => item.json);\n\nconst voiceMap = {};\nfor (const v of voices) {\n  if (v.lang) voiceMap[v.lang] = v;\n}\n\nconst segments = $input.all().map(item => item.json);\n\nconst merged = [];\nlet skippedNoVoice = 0;\nlet skippedNoTranslation = 0;\nlet skippedAlreadyDone = 0;\n\nfor (const seg of segments) {\n  const voice = voiceMap[seg.lang];\n  \n  if (!voice) {\n    skippedNoVoice++;\n    continue;\n  }\n  \n  if (!seg.text_translated || String(seg.text_translated).trim() === '') {\n    skippedNoTranslation++;\n    continue;\n  }\n  \n  if (seg.real_duration_sec && parseFloat(seg.real_duration_sec) > 0) {\n    skippedAlreadyDone++;\n    continue;\n  }\n  \n  merged.push({\n    json: {\n      segment_id: seg.segment_id,\n      lang: seg.lang,\n      text_translated: String(seg.text_translated).replace(/\"/g, \"'\"),\n      en_start_sec: parseFloat(seg.en_start_sec) || 0,\n      voice_id: voice.voice_id,\n      model: voice.model || 'eleven_multilingual_v2',\n      stability: parseFloat(voice.stability) || 0.5,\n      similarity_boost: parseFloat(voice.similarity_boost) || 0.75,\n      style: parseFloat(voice.style) || 0,\n      speed: parseFloat(voice.speed) || 1.0,\n      row_key: `${seg.segment_id}_${seg.lang}`\n    }\n  });\n}\n\nconsole.log(`Prepared ${merged.length} TTS jobs`);\nconsole.log(`Skipped: ${skippedNoVoice} no voice, ${skippedNoTranslation} no translation, ${skippedAlreadyDone} already done`);\n\nif (merged.length === 0) {\n  throw new Error('No segments to synthesize. Check Localizations and Voices sheets.');\n}\n\nreturn merged;"
      },
