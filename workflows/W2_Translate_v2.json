    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "let toneMap = {};\ntry {\n  let raw = $input.first().json.content?.[0]?.text?.trim() || '{}';\n  const match = raw.match(/\\{[\\s\\S]*\\}/);\n  if (!match) throw new Error('No JSON in response');\n  toneMap = JSON.parse(match[0]);\n} catch (e) {\n  throw new Error('Tone parse failed: ' + e.message);\n}\nif (Object.keys(toneMap).length === 0) throw new Error('Tone analysis returned empty object');\nreturn Object.entries(toneMap).map(([segment_id, meta]) => ({\n  json: { segment_id, segment_type: meta.segment_type || 'narrative', movement_keywords: meta.movement_keywords || '', key_concepts: meta.key_concepts || '' }\n}));"
      },
