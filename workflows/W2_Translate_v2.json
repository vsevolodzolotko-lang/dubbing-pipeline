    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const segments = $input.all()\n  .filter(i => i.json.segment_id && i.json.en_text)\n  .map(i => ({ segment_id: i.json.segment_id, en_text: i.json.en_text }));\nif (segments.length === 0) throw new Error('No segments to analyze');\nconst sysPrompt = 'Classify each wellness/meditation segment. Return ONLY a JSON object where each key is segment_id and value has: segment_type (narrative|instruction|movement), movement_keywords (comma-sep if movement, else empty string), key_concepts (2-4 comma-sep themes). No markdown, no preamble.';\nreturn [{ json: { model: 'claude-sonnet-4-5', max_tokens: 2000, system: sysPrompt, messages: [{ role: 'user', content: 'Segments:\\n\\n' + JSON.stringify(segments, null, 2) }] } }];"
      },
      "id": "tone-prep-node-001",
      "name": "Prepare Tone Analysis",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2224,
