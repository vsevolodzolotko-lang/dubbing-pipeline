    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const results = [];\nconst preparedItems = $('Prepare and Expand').all();\n\nfor (let i = 0; i < $input.all().length; i++) {\n  const claudeResp = $input.all()[i].json;\n  const sourceItem = preparedItems[i]?.json || {};\n\n  let translations = {};\n  try {\n    let text = claudeResp.content?.[0]?.text?.trim() || '{}';\n    text = text.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n    const match = text.match(/\\{[\\s\\S]*\\}/);\n    if (match) translations = JSON.parse(match[0]);\n  } catch(e) {\n    console.log('Parse error for segment:', sourceItem.segment_id, e.message);\n  }\n\n  results.push({ json: {\n    segment_id: sourceItem.segment_id,\n    de_text: translations.de || '',\n    es_text: translations.es || '',\n    fr_text: translations.fr || '',\n    pl_text: translations.pl || '',\n    pt_text: translations.pt || '',\n    it_text: translations.it || '',\n    tr_text: translations.tr || '',\n  }});\n}\nreturn results;"
      },
